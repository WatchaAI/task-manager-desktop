{
  "name": "task-manager-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "A local desktop task manager with SQLite persistence.",
  "main": "electron/main.cjs",
  "scripts": {
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -v 39.8.10 -f -w better-sqlite3",
    "dev": "npm run rebuild:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "test": "npm run rebuild:node && vitest run",
    "dist": "npm run build && npm run rebuild:electron && rm -rf release && USE_HARD_LINKS=false electron-builder --mac --dir --config.npmRebuild=false && npm run rebuild:node"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.10.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "39.8.10",
    "electron-builder": "^26.0.12",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "local.task-manager-desktop",
    "productName": "Task Manager Desktop",
    "buildDependenciesFromSource": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
